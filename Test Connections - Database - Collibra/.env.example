# Collibra API Client Configuration
# Copy this file to .env and fill in your actual credentials
#
# You can use EITHER OAuth 2.0 OR Basic Authentication (username/password)

# ============================================================================
# Required: Base URL
# ============================================================================
COLLIBRA_BASE_URL=https://your-instance.collibra.com

# ============================================================================
# Authentication Method 1: OAuth 2.0 (Recommended)
# ============================================================================
# Get these from Collibra: Settings > OAuth Applications
# Create a new OAuth application if you don't have one yet
#
# Use OAuth 2.0 for:
# - All REST API v2.0 endpoints
# - Catalog Database Registration API
# - GraphQL API
#
COLLIBRA_CLIENT_ID=your_oauth_client_id
COLLIBRA_CLIENT_SECRET=your_oauth_client_secret

# ============================================================================
# Authentication Method 2: Basic Authentication (Alternative)
# ============================================================================
# Use your Collibra username and password
#
# Basic Auth is supported for:
# - Catalog Database Registration API
# - Some legacy endpoints
#
# Note: If both OAuth and Basic Auth are provided, OAuth will be used by default.
#
# COLLIBRA_USERNAME=your_collibra_username
# COLLIBRA_PASSWORD=your_collibra_password

# ============================================================================
# Optional: Request Timeout
# ============================================================================
# Default timeout is 30 seconds. Uncomment and adjust if needed:
# COLLIBRA_TIMEOUT=30
